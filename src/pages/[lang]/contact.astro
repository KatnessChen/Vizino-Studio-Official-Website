---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh-tw' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);
---

<Layout title="Contact — Well Maintained" lang={lang}>
  <section class="legal-page">
    <div class="legal-container">
      <h1>Contact</h1>
      <p class="legal-intro">Have questions? Reach out to us at <a href="mailto:contact@vizino.ai" style="color: var(--accent);">contact@vizino.ai</a></p>
    </div>
  </section>
</Layout>

<style>
  .legal-page { padding: 120px 24px 80px; }
  .legal-container { max-width: 720px; margin: 0 auto; }
  .legal-container h1 { font-size: clamp(32px, 5vw, 44px); font-weight: 800; margin-bottom: 16px; }
  .legal-intro { font-size: 17px; color: var(--text-secondary); line-height: 1.7; }
</style>
