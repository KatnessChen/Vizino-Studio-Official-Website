---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh-tw' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);

// ── Form backend ──────────────────────────────────────────────
// Submissions (including the uploaded inspection report) are sent to you by
// email via Web3Forms (free, supports file attachments, no backend needed).
// 1. Get a free access key at https://web3forms.com (uses contact@vizino.ai)
// 2. Paste it below. Until then the form runs in DEMO mode (shows success,
//    sends nothing). Tip: store it in .env as PUBLIC_WEB3FORMS_KEY instead.
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

// ── Path B (upload report) ────────────────────────────────────
// Web3Forms file attachments are a paid feature, so the "upload report"
// path instead opens the visitor's email app pre-filled, and they attach
// the report themselves. Change this to whichever inbox you actually read.
const REPORT_EMAIL = 'contact@vizino.ai';
---

<Layout title={t('intake.title') + ' — Well Maintained'} lang={lang}>
  <section class="intake-page">
    <div class="intake-container">
      <h1 class="intake-title">{t('intake.title')}</h1>
      <p class="intake-desc">{t('intake.description')}</p>

      <!-- Path toggle -->
      <div class="path-toggle">
        <button type="button" class="path-btn active" data-path="A" id="pathA">
          <span class="path-tag">{t('intake.tag.free')}</span>
          <span class="path-t">{t('intake.path.a.title')}</span>
          <span class="path-d">{t('intake.path.a.desc')}</span>
        </button>
        <button type="button" class="path-btn" data-path="B" id="pathB">
          <span class="path-tag">{t('intake.tag.free')}</span>
          <span class="path-t">{t('intake.path.b.title')}</span>
          <span class="path-d">{t('intake.path.b.desc')}</span>
        </button>
        <button type="button" class="path-btn" data-path="C" id="pathC">
          <span class="path-tag paid">{t('intake.tag.visit')}</span>
          <span class="path-t">{t('intake.path.c.title')}</span>
          <span class="path-d">{t('intake.path.c.desc')}</span>
        </button>
      </div>

      <form class="intake-form" id="intakeForm" data-key={WEB3FORMS_KEY}
            data-mail-to={REPORT_EMAIL}
            data-submit-a={t('intake.submit')}
            data-submit-b={t('intake.submit.email')}
            data-submit-c={t('intake.submit.visit')}>
        <!-- Web3Forms config -->
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New Well Maintained schedule request" />
        <input type="hidden" name="from_name" value="Well Maintained intake" />
        <input type="hidden" name="path" id="pathField" value="questions" />

        <!-- Always required (Path A only) -->
        <div id="qsRequired">
        <div class="row">
          <div class="field">
            <label for="name">{t('intake.name')} <span class="req">*</span></label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="field">
            <label for="email">{t('intake.email')} <span class="req">*</span></label>
            <input type="email" id="email" name="email" required />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label for="location">{t('intake.location')} <span class="req">*</span></label>
            <input type="text" id="location" name="location" required placeholder={t('intake.location.placeholder')} />
            <span class="hint">{t('intake.location.hint')}</span>
          </div>
          <div class="field">
            <label for="replyLang">{t('intake.replyLang')} <span class="req">*</span></label>
            <input type="text" id="replyLang" name="replyLang" list="langOptions" required
                   placeholder={t('intake.replyLang.placeholder')} autocomplete="off" />
            <datalist id="langOptions">
              <option value="English"></option>
              <option value="Français"></option>
              <option value="中文"></option>
            </datalist>
            <span class="hint">{t('intake.replyLang.hint')}</span>
          </div>
        </div>
        </div>

        <!-- PATH A — questions -->
        <div id="qsA">
          <div class="row">
            <div class="field">
              <label for="age">{t('intake.age')}</label>
              <select id="age" name="age">
                <option value="">{t('intake.select')}</option>
                <option value="0-5">{t('intake.age.new')}</option>
                <option value="6-15">{t('intake.age.6')}</option>
                <option value="16-30">{t('intake.age.16')}</option>
                <option value="31-50">{t('intake.age.31')}</option>
                <option value="50+">{t('intake.age.50')}</option>
                <option value="unsure">{t('intake.age.unsure')}</option>
              </select>
            </div>
            <div class="field">
              <label for="homeType">{t('intake.type')}</label>
              <select id="homeType" name="homeType">
                <option value="">{t('intake.select')}</option>
                <option value="detached">{t('intake.type.detached')}</option>
                <option value="semi">{t('intake.type.semi')}</option>
                <option value="townhouse">{t('intake.type.townhouse')}</option>
                <option value="condo">{t('intake.type.condo')}</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label for="size">{t('intake.size')}</label>
              <select id="size" name="size">
                <option value="">{t('intake.select')}</option>
                <option value="u1000">{t('intake.size.u1000')}</option>
                <option value="1000-1500">{t('intake.size.1000')}</option>
                <option value="1500-2000">{t('intake.size.1500')}</option>
                <option value="2000-2500">{t('intake.size.2000')}</option>
                <option value="2500+">{t('intake.size.2500')}</option>
                <option value="unsure">{t('intake.size.unsure')}</option>
              </select>
            </div>
            <div class="field">
              <label for="heating">{t('intake.heating')}</label>
              <select id="heating" name="heating">
                <option value="">{t('intake.select')}</option>
                <option value="gas">{t('intake.heating.gas')}</option>
                <option value="electric">{t('intake.heating.electric')}</option>
                <option value="heatpump">{t('intake.heating.heatpump')}</option>
                <option value="boiler">{t('intake.heating.boiler')}</option>
                <option value="unsure">{t('intake.heating.unsure')}</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label for="cooling">{t('intake.cooling')}</label>
              <select id="cooling" name="cooling">
                <option value="">{t('intake.select')}</option>
                <option value="central">{t('intake.cooling.central')}</option>
                <option value="ductless">{t('intake.cooling.ductless')}</option>
                <option value="window">{t('intake.cooling.window')}</option>
                <option value="none">{t('intake.cooling.none')}</option>
                <option value="unsure">{t('intake.cooling.unsure')}</option>
              </select>
            </div>
            <div class="field">
              <label for="water">{t('intake.water')}</label>
              <select id="water" name="water">
                <option value="">{t('intake.select')}</option>
                <option value="city">{t('intake.water.city')}</option>
                <option value="well">{t('intake.water.well')}</option>
                <option value="mixed">{t('intake.water.mixed')}</option>
                <option value="unsure">{t('intake.water.unsure')}</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label for="waterheater">{t('intake.waterheater')}</label>
              <select id="waterheater" name="waterheater">
                <option value="">{t('intake.select')}</option>
                <option value="gastank">{t('intake.waterheater.gastank')}</option>
                <option value="electrictank">{t('intake.waterheater.electrictank')}</option>
                <option value="tankless">{t('intake.waterheater.tankless')}</option>
                <option value="unsure">{t('intake.waterheater.unsure')}</option>
              </select>
            </div>
            <div class="field">
              <label for="waterheaterAge">{t('intake.waterheaterage')}</label>
              <select id="waterheaterAge" name="waterheaterAge">
                <option value="">{t('intake.select')}</option>
                <option value="u5">{t('intake.waterheaterage.u5')}</option>
                <option value="5-10">{t('intake.waterheaterage.5')}</option>
                <option value="10+">{t('intake.waterheaterage.10')}</option>
                <option value="unsure">{t('intake.waterheaterage.unsure')}</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="field">
              <label for="roof">{t('intake.roof')}</label>
              <select id="roof" name="roof">
                <option value="">{t('intake.select')}</option>
                <option value="u5">{t('intake.roof.u5')}</option>
                <option value="5-15">{t('intake.roof.5')}</option>
                <option value="16-25">{t('intake.roof.16')}</option>
                <option value="25+">{t('intake.roof.25')}</option>
                <option value="unsure">{t('intake.roof.unsure')}</option>
              </select>
            </div>
            <div class="field">
              <label for="roofMat">{t('intake.roofmat')}</label>
              <select id="roofMat" name="roofMat">
                <option value="">{t('intake.select')}</option>
                <option value="asphalt">{t('intake.roofmat.asphalt')}</option>
                <option value="metal">{t('intake.roofmat.metal')}</option>
                <option value="flat">{t('intake.roofmat.flat')}</option>
                <option value="other">{t('intake.roofmat.other')}</option>
                <option value="unsure">{t('intake.roofmat.unsure')}</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label>{t('intake.features')}</label>
            <div class="checks">
              <label class="check"><input type="checkbox" name="features" value="gutters" /> {t('intake.features.gutters')}</label>
              <label class="check"><input type="checkbox" name="features" value="deck" /> {t('intake.features.deck')}</label>
              <label class="check"><input type="checkbox" name="features" value="fireplace" /> {t('intake.features.fireplace')}</label>
              <label class="check"><input type="checkbox" name="features" value="sump" /> {t('intake.features.sump')}</label>
              <label class="check"><input type="checkbox" name="features" value="irrigation" /> {t('intake.features.irrigation')}</label>
              <label class="check"><input type="checkbox" name="features" value="pool" /> {t('intake.features.pool')}</label>
              <label class="check"><input type="checkbox" name="features" value="garage" /> {t('intake.features.garage')}</label>
              <label class="check"><input type="checkbox" name="features" value="trees" /> {t('intake.features.trees')}</label>
            </div>
          </div>
          <div class="field">
            <label for="diy">{t('intake.diy')}</label>
            <select id="diy" name="diy">
              <option value="">{t('intake.select')}</option>
              <option value="self">{t('intake.diy.self')}</option>
              <option value="mix">{t('intake.diy.mix')}</option>
              <option value="pro">{t('intake.diy.pro')}</option>
            </select>
          </div>
        </div>

        <!-- PATH B — email report -->
        <div id="qsB" class="hidden">
          <div class="mail-card">
            <div class="mail-ic">📄</div>
            <p class="mail-lead">{t('intake.mail.lead')}</p>
            <p class="mail-note">{t('intake.mail.note')}</p>
            <a class="mail-addr" href={"mailto:" + REPORT_EMAIL}>{REPORT_EMAIL}</a>
          </div>
        </div>

        <!-- PATH C — in-home visit -->
        <div id="qsC" class="hidden">
          <div class="mail-card">
            <div class="mail-ic">🧑‍🔧</div>
            <p class="mail-lead">{t('intake.visit.lead')}</p>
            <p class="visit-price">{t('intake.visit.price')}</p>
            <p class="mail-note">{t('intake.visit.note')}</p>
            <a class="mail-addr" href={"mailto:" + REPORT_EMAIL}>{REPORT_EMAIL}</a>
            <p class="visit-fineprint">{t('intake.visit.fineprint')}</p>
          </div>
        </div>

        <!-- Shared optional -->
        <div id="qsWorry" class="field">
          <label for="worry">{t('intake.worry')}</label>
          <textarea id="worry" name="worry" rows="3"></textarea>
        </div>

        <button type="submit" class="btn-primary submit-btn" id="submitBtn"><span id="submitLabel">{t('intake.submit')}</span> &rarr;</button>
      </form>

      <div class="success-msg" id="successMsg"
           data-title-a={t('intake.success.title')} data-body-a={t('intake.success.body')}
           data-title-b={t('intake.mail.success.title')} data-body-b={t('intake.mail.success.body')}
           data-title-c={t('intake.visit.success.title')} data-body-c={t('intake.visit.success.body')}>
        <div class="success-icon">&#10003;</div>
        <h2 class="success-title" id="successTitle">{t('intake.success.title')}</h2>
        <p id="successBody">{t('intake.success.body')}</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .intake-page {
    min-height: 100vh;
    padding: 160px 28px 110px;
    display: flex;
    justify-content: center;
  }
  .intake-container {
    max-width: 660px;
    width: 100%;
  }
  .intake-title {
    font-size: clamp(30px, 5vw, 44px);
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .intake-desc {
    font-size: 17px;
    color: var(--text-secondary);
    margin-bottom: 44px;
    line-height: 1.7;
  }

  /* Path toggle */
  .path-toggle {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 40px;
  }
  .path-btn {
    position: relative;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px 18px 18px;
    text-align: left;
    cursor: pointer;
    font-family: var(--font);
    color: var(--text-secondary);
    transition: border-color 0.2s, background 0.2s;
  }
  .path-tag {
    position: absolute;
    top: -10px;
    right: 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3px;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--accent);
    color: var(--bg-primary);
    white-space: nowrap;
  }
  .path-tag.paid {
    background: var(--amber);
  }
  .path-btn .path-t {
    display: block;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .path-btn .path-d {
    display: block;
    font-size: 13px;
    line-height: 1.5;
  }
  .path-btn.active {
    border-color: var(--accent);
    background: var(--accent-subtle);
  }
  #pathC.active {
    border-color: var(--amber);
    background: rgba(255, 184, 0, 0.1);
  }

  /* Form */
  .intake-form {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  #qsA {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .req { color: var(--accent); }
  .field input[type="text"],
  .field input[type="email"],
  .field select,
  .field textarea {
    padding: 14px 16px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-primary);
    font-size: 16px;
    font-family: var(--font);
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
  }
  .field textarea { resize: vertical; }
  .field select {
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23666666' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus { border-color: var(--accent); }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--text-tertiary); }
  .hint {
    font-size: 12px;
    color: var(--text-tertiary);
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
  }

  /* Checkboxes */
  .checks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .check {
    display: flex;
    align-items: center;
    gap: 9px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 13px 15px;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-primary);
    text-transform: none;
    letter-spacing: 0;
    cursor: pointer;
  }
  .check input { accent-color: var(--accent); width: 16px; height: 16px; }

  /* Email-report card (Path B) */
  .mail-card {
    border: 1.5px dashed var(--border);
    border-radius: var(--radius);
    padding: 28px;
    text-align: center;
    background: var(--bg-secondary);
  }
  .mail-ic { font-size: 30px; }
  .mail-lead { color: var(--text-primary); font-size: 15px; font-weight: 600; margin-top: 10px; }
  .visit-price { color: var(--accent); font-size: 16px; font-weight: 700; margin-top: 14px; }
  .mail-note { color: var(--text-secondary); font-size: 14px; line-height: 1.6; margin-top: 8px; }
  .mail-addr { display: inline-block; margin-top: 8px; color: var(--accent); font-size: 16px; font-weight: 700; text-decoration: none; }
  .mail-addr:hover { text-decoration: underline; }
  .visit-fineprint { color: var(--text-tertiary); font-size: 12px; margin-top: 14px; }
  .hidden { display: none !important; }

  .submit-btn {
    margin-top: 4px;
    width: 100%;
    font-size: 17px;
    padding: 16px;
    background: var(--accent);
    color: var(--bg-primary);
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-family: var(--font);
    cursor: pointer;
    transition: background 0.2s;
  }
  .submit-btn:hover { background: var(--accent-hover); }
  .submit-btn:disabled { opacity: 0.6; cursor: default; }
  .privacy {
    font-size: 13px;
    color: var(--text-tertiary);
    text-align: center;
  }

  /* Success */
  .success-msg { display: none; text-align: center; padding: 48px 0; }
  .success-msg.show { display: block; }
  .success-icon {
    width: 64px;
    height: 64px;
    background: var(--accent);
    color: var(--bg-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    margin: 0 auto 20px;
  }
  .success-title { font-size: 24px; font-weight: 700; margin-bottom: 10px; }
  .success-msg p { font-size: 17px; color: var(--text-secondary); line-height: 1.6; }

  @media (max-width: 600px) {
    .row, .checks, .path-toggle { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('intakeForm') as HTMLFormElement;
  const successMsg = document.getElementById('successMsg') as HTMLElement;
  const successTitle = document.getElementById('successTitle');
  const successBody = document.getElementById('successBody');
  const pathToggle = document.querySelector('.path-toggle') as HTMLElement;
  const pathField = document.getElementById('pathField') as HTMLInputElement;
  const qsA = document.getElementById('qsA');
  const qsB = document.getElementById('qsB');
  const qsC = document.getElementById('qsC');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submitLabel');
  const accessKey = form?.dataset.key || '';
  const mailTo = form?.dataset.mailTo || '';
  const labelA = form?.dataset.submitA || '';
  const labelB = form?.dataset.submitB || '';
  const labelC = form?.dataset.submitC || '';

  function showSuccess(variant: 'a' | 'b' | 'c') {
    const ds = successMsg.dataset;
    const title = variant === 'a' ? ds.titleA : variant === 'b' ? ds.titleB : ds.titleC;
    const body = variant === 'a' ? ds.bodyA : variant === 'b' ? ds.bodyB : ds.bodyC;
    if (successTitle && title) successTitle.textContent = title;
    if (successBody && body) successBody.textContent = body;
    form.style.display = 'none';
    pathToggle.style.display = 'none';
    successMsg.classList.add('show');
  }

  // Path toggle
  document.querySelectorAll('.path-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const path = (btn as HTMLElement).dataset.path; // 'A' | 'B' | 'C'
      document.getElementById('pathA')?.classList.toggle('active', path === 'A');
      document.getElementById('pathB')?.classList.toggle('active', path === 'B');
      document.getElementById('pathC')?.classList.toggle('active', path === 'C');
      qsA?.classList.toggle('hidden', path !== 'A');
      qsB?.classList.toggle('hidden', path !== 'B');
      qsC?.classList.toggle('hidden', path !== 'C');
      if (pathField) pathField.value = path === 'A' ? 'questions' : path === 'B' ? 'report' : 'visit';
      if (submitLabel) submitLabel.textContent = path === 'A' ? labelA : path === 'B' ? labelB : labelC;
      const isA = path === 'A';
      if (submitBtn) submitBtn.style.display = isA ? '' : 'none';
      const reqEl = document.getElementById('qsRequired');
      const worryEl = document.getElementById('qsWorry');
      if (reqEl) reqEl.style.display = isA ? '' : 'none';
      if (worryEl) worryEl.style.display = isA ? '' : 'none';
    });
  });

  const val = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    return el ? el.value.trim() : '';
  };

  // Submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const mode = pathField?.value; // 'questions' | 'report' | 'visit'

    // Path B / C: submit button is hidden; this branch is a no-op safeguard.
    if (mode === 'report' || mode === 'visit') return;

    // ── Path A → Web3Forms ──
    // DEMO mode: no access key configured yet → just show success.
    if (!accessKey) { showSuccess('a'); return; }

    if (submitBtn) submitBtn.disabled = true;
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        showSuccess('a');
      } else {
        if (submitBtn) submitBtn.disabled = false;
        alert('Something went wrong. Please email ' + (mailTo || 'contact@vizino.ai') + ' directly.');
      }
    } catch {
      if (submitBtn) submitBtn.disabled = false;
      alert('Something went wrong. Please email ' + (mailTo || 'contact@vizino.ai') + ' directly.');
    }
  });
</script>
