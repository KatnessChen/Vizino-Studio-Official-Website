---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh-tw' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);
const wlang = lang === 'zh-tw' ? 'zh' : 'en';
---

<Layout title={t('ss.meta.title')} description={t('ss.meta.description')} lang={lang}>

  <!-- ═══ HERO ═══ -->
  <section class="ss-hero">
    <div class="ss-wrap">
      <div class="ss-eyebrow">{t('ss.eyebrow')}</div>
      <h1 class="ss-h1">{t('ss.headline')}</h1>
      <p class="ss-intro">{t('ss.intro')}</p>
      <div class="ss-demo-note">{t('ss.demoNote')}</div>
    </div>
  </section>

  <!-- ═══ INTERACTIVE WIDGET ═══ -->
  <section class="ss-section">
    <div class="ss ss-wrap" data-lang={wlang}>
      <div class="ss-panel" id="ss-panel"></div>
      <div class="ss-summary" id="ss-summary"></div>
      <div class="ss-cal" id="ss-out"></div>
      <div class="ss-calcta" id="ss-calcta"></div>
    </div>
  </section>

  <!-- detail modal -->
  <div class="ss-modal" id="ss-modal" hidden>
    <div class="ss-modal-backdrop" id="ss-modal-bd"></div>
    <div class="ss-modal-card" id="ss-modal-card" role="dialog" aria-modal="true"></div>
  </div>

</Layout>

<style is:global>
  /* ===== Smart Schedule page (namespaced .ss*) ===== */
  .ss-wrap{max-width:1100px;margin:0 auto;padding:0 24px}
  .ss-hero{padding:128px 0 24px}
  .ss-eyebrow{color:var(--accent);text-transform:uppercase;letter-spacing:.18em;font-size:13px;font-weight:600;margin-bottom:14px}
  .ss-h1{font-size:clamp(32px,5vw,50px);font-weight:800;line-height:1.08;letter-spacing:-.02em;max-width:860px}
  .ss-intro{color:var(--text-secondary);font-size:clamp(16px,2.2vw,19px);margin:20px 0 0;max-width:700px;line-height:1.7}
  .ss-demo-note{display:inline-block;margin-top:22px;background:var(--accent-subtle);border:1px solid var(--border);color:var(--accent);font-size:13px;border-radius:10px;padding:9px 14px}
  .ss-feats{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-top:34px}
  .ss-feat{background:var(--bg-secondary);border:1px solid var(--border);border-radius:12px;padding:14px 10px;text-align:center}
  .ss-feat .ic{font-size:22px}
  .ss-feat .ft{font-size:12.5px;font-weight:600;margin-top:8px;line-height:1.3;color:var(--text-primary)}

  .ss-section{padding:24px 0 96px}
  .ss{--ss-accent-sub:rgba(92,240,163,0.12);--ss-amber-sub:rgba(255,184,0,0.12);--ss-danger-sub:rgba(255,77,77,0.12)}

  /* Panel */
  .ss-panel{background:var(--bg-secondary);border:1px solid var(--border);border-radius:16px;padding:24px}
  .ss-panel h2{font-size:18px;font-weight:700}
  .ss-panel .ss-hint{color:var(--text-secondary);font-size:13px;margin-top:4px}
  .ss-controls{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:20px}
  .ss-ctl label{display:block;font-size:12px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.04em;margin-bottom:7px}
  .ss-ctl select{width:100%;background:var(--bg-primary);border:1px solid var(--border);border-radius:10px;padding:11px 12px;color:var(--text-primary);font-size:14px;font-family:var(--font)}
  .ss-ctl select:focus{outline:none;border-color:var(--accent)}
  .ss-feat-label{font-size:12px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.04em;margin:20px 0 10px}
  .ss-chips{display:flex;flex-wrap:wrap;gap:9px}
  .ss-chip{display:inline-flex;align-items:center;gap:7px;background:var(--bg-primary);border:1px solid var(--border);border-radius:999px;padding:8px 14px;font-size:13.5px;color:var(--text-secondary);cursor:pointer;user-select:none;transition:.12s}
  .ss-chip:hover{border-color:var(--accent)}
  .ss-chip.on{background:var(--ss-accent-sub);border-color:var(--accent);color:var(--text-primary)}
  .ss-chip .dot{width:8px;height:8px;border-radius:50%;background:var(--text-tertiary)}
  .ss-chip.on .dot{background:var(--accent)}

  /* Summary */
  .ss-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:22px}
  .ss-stat{background:var(--bg-secondary);border:1px solid var(--border);border-radius:14px;padding:18px}
  .ss-stat .n{font-size:26px;font-weight:800;color:var(--accent)}
  .ss-stat .n.amber{color:var(--amber)}
  .ss-stat .n.plain{color:var(--text-primary)}
  .ss-stat .l{font-size:12.5px;color:var(--text-secondary);margin-top:4px;line-height:1.35}

  /* Calendar CTA */
  .ss-calcta{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px;background:linear-gradient(100deg,var(--accent-subtle),transparent 80%);border:1px solid var(--border);border-radius:16px;padding:22px 24px;margin-top:22px}
  .ss-calcta .ss-cta-txt h3{font-size:18px;font-weight:700}
  .ss-calcta .ss-cta-txt p{color:var(--text-secondary);font-size:13.5px;margin-top:4px;max-width:560px;line-height:1.6}
  .ss-howlink{color:var(--accent);font-size:13px;cursor:pointer;text-decoration:underline;background:none;border:none;font-family:var(--font);margin-top:10px;display:inline-block;padding:0}
  .ss-howbox{display:none;margin-top:12px;background:var(--bg-primary);border:1px solid var(--border);border-radius:10px;padding:14px 16px;font-size:13px;color:var(--text-secondary);line-height:1.6}
  .ss-howbox.show{display:block}
  .ss-howbox ol{margin:6px 0 0 18px}

  /* ===== Single-month calendar view ===== */
  .ss-cal{margin-top:30px}
  .ss-calnav{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;padding-bottom:16px;border-bottom:1px solid var(--border)}
  .ss-calnav-main{display:flex;align-items:center;gap:16px}
  .ss-navbtn{width:40px;height:40px;border-radius:10px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-primary);font-size:20px;line-height:1;cursor:pointer;font-family:var(--font);transition:.12s}
  .ss-navbtn:hover{border-color:var(--accent);color:var(--accent)}
  .ss-navlabel{display:flex;align-items:baseline;gap:10px;min-width:150px;justify-content:center}
  .ss-navlabel .m{font-size:26px;font-weight:800;letter-spacing:-.01em}
  .ss-navlabel .season{font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.1em}
  .ss-calnav-side{display:flex;align-items:center;gap:14px}
  .ss-calnav-side .count{font-size:13px;color:var(--text-tertiary)}
  .ss-today{font-size:13px;font-weight:600;color:var(--accent);background:var(--ss-accent-sub);border:1px solid var(--border);border-radius:999px;padding:7px 14px;cursor:pointer;font-family:var(--font);transition:.12s}
  .ss-today:hover{border-color:var(--accent)}

  .ss-rows{display:flex;flex-direction:column;gap:10px;margin-top:18px}
  .ss-row{display:flex;align-items:center;gap:12px;background:var(--bg-secondary);border:1px solid var(--border);border-left:3px solid var(--text-tertiary);border-radius:12px;padding:14px 16px;cursor:pointer;transition:.12s}
  .ss-row:hover{border-color:var(--accent);transform:translateY(-1px)}
  .ss-row:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
  .ss-row.p-high{border-left-color:var(--danger)}
  .ss-row.p-med{border-left-color:var(--amber)}
  .ss-row.p-low{border-left-color:var(--accent)}
  .ss-dot{flex:0 0 auto;width:9px;height:9px;border-radius:50%;background:var(--text-tertiary)}
  .ss-dot.high{background:var(--danger)} .ss-dot.med{background:var(--amber)} .ss-dot.low{background:var(--accent)}
  .ss-rowtitle{flex:1;font-size:15.5px;font-weight:600;line-height:1.35}
  .ss-rowtags{display:flex;align-items:center;gap:8px}
  .ss-chev{color:var(--text-tertiary);font-size:20px;line-height:1}
  .ss-empty{color:var(--text-tertiary);font-size:15px;padding:40px 20px;text-align:center;border:1px dashed var(--border);border-radius:12px;margin-top:18px}

  .ss-badge{font-size:11.5px;font-weight:600;padding:4px 10px;border-radius:8px;white-space:nowrap}
  .ss-badge.easy{background:var(--ss-accent-sub);color:var(--accent)}
  .ss-badge.moderate{background:var(--ss-amber-sub);color:var(--amber)}
  .ss-badge.pro{background:var(--ss-danger-sub);color:var(--danger)}
  .ss-pri{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;padding:4px 10px;border-radius:999px;white-space:nowrap;display:inline-block}
  .ss-pri.high{background:var(--ss-danger-sub);color:var(--danger)}
  .ss-pri.med{background:var(--ss-amber-sub);color:var(--amber)}
  .ss-pri.low{background:var(--ss-accent-sub);color:var(--accent)}
  .ss-note{font-size:11px;color:var(--text-tertiary);font-weight:400;text-transform:none;letter-spacing:0}

  /* ===== Detail modal ===== */
  .ss-modal{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;padding:24px}
  .ss-modal[hidden]{display:none}
  .ss-modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
  .ss-modal-card{position:relative;z-index:1;background:var(--bg-secondary);border:1px solid var(--border);border-radius:18px;padding:28px;width:100%;max-width:460px;box-shadow:0 24px 70px rgba(0,0,0,.5);animation:ssPop .16s ease-out}
  @keyframes ssPop{from{opacity:0;transform:translateY(10px) scale(.98)}to{opacity:1;transform:none}}
  .ss-modal-close{position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-tertiary);font-size:26px;line-height:1;cursor:pointer;font-family:var(--font)}
  .ss-modal-close:hover{color:var(--text-primary)}
  .ss-modal-title{font-size:22px;font-weight:750;line-height:1.25;margin:12px 0 6px;padding-right:24px}
  .ss-modal-sys{font-size:13px;color:var(--text-secondary)}
  .ss-modal-desc{font-size:14.5px;color:var(--text-secondary);line-height:1.65;margin-top:16px}
  .ss-modal-meta{margin-top:18px;border-top:1px solid var(--border)}
  .ss-modal-line{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
  .ss-modal-line .k{font-size:13px;color:var(--text-tertiary)}
  .ss-modal-line .v{font-size:14px;color:var(--text-primary);font-weight:600;text-align:right}
  .ss-gcal{display:inline-flex;align-items:center;gap:6px;color:var(--accent);text-decoration:none;border:1px solid var(--border);border-radius:999px;padding:6px 12px;font-size:12.5px;transition:.12s}
  .ss-gcal:hover{border-color:var(--accent);background:var(--ss-accent-sub)}
  .ss-modal-gcal{width:100%;justify-content:center;margin-top:20px;padding:13px;font-size:14.5px;font-weight:600}

  @media (max-width:860px){
    .ss-feats{grid-template-columns:repeat(3,1fr)}
    .ss-controls{grid-template-columns:repeat(2,1fr)}
    .ss-summary{grid-template-columns:repeat(2,1fr)}
  }
  @media (max-width:520px){ .ss-feats{grid-template-columns:repeat(2,1fr)} }
</style>

<script>
  const root = document.querySelector('.ss');
  if (root) {
    const lang = root.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
    const currentMonth = () => new Date().getMonth() + 1;

    const STATE = {
      month: currentMonth(),
      climate: 'cold', age: 'older', heating: 'gas', diy: 'mix',
      features: { gutters:true, sump:true, fireplace:true, garage:true, trees:true, deck:false, irrigation:false, pool:false }
    };

