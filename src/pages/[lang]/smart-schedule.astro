      {id:'pool_close',en:'Close & winterize the pool',zh:'關池與冬化泳池',sysEn:'Exterior',sysZh:'外部',freq:'annual',months:[9],pri:'med',cost:{diy:150,proLow:300,proHigh:600},diff:'moderate',req:'pool',descEn:'Balance water, lower the level, add winter chemicals, and cover it to protect the pool over winter.',descZh:'平衡水質、降低水位、加入冬季藥劑並蓋上池蓋，保護泳池過冬。'},
      {id:'sealgaps',en:'Seal gaps & service heating before cold',zh:'封堵縫隙並在寒冬前保養暖氣',sysEn:'Exterior',sysZh:'外部',freq:'seasonal',months:[11],pri:'med',cost:{diy:20,proLow:null,proHigh:null},diff:'easy',descEn:'Caulk exterior gaps and book any heating service before the first cold snap so you are not caught out.',descZh:'在第一波寒流前填補外部縫隙並預約暖氣保養，免得措手不及。'},
      {id:'hrv',en:'HRV / ERV cleaning & balancing',zh:'熱回收通風系統清潔與平衡',sysEn:'HVAC',sysZh:'暖通空調',freq:'annual',months:[2],pri:'med',cost:{diy:0,proLow:120,proHigh:200},diff:'moderate',descEn:'Clean the cores and filters of your HRV/ERV and rebalance airflow for fresh, efficient ventilation.',descZh:'清潔 HRV／ERV 的核心與濾網並重新平衡氣流，維持新鮮又高效的通風。'},
      {id:'whflush',en:'Flush water heater; test relief valve',zh:'沖洗熱水器；測試洩壓閥',sysEn:'Plumbing',sysZh:'水管',freq:'annual',months:[3],pri:'med',cost:{diy:0,proLow:100,proHigh:150},diff:'moderate',descEn:'Fully flush the tank and test the pressure-relief valve to keep the water heater safe and efficient.',descZh:'徹底沖洗水箱並測試洩壓閥，維持熱水器安全與效率。'},
      {id:'rekey',en:'Re-key exterior locks (new owners)',zh:'重設外門鎖（新屋主）',sysEn:'Security',sysZh:'安全',freq:'annual',months:[8],pri:'low',cost:{diy:30,proLow:80,proHigh:150},diff:'moderate',firstYearOnly:true,descEn:'New to the home? Re-key or replace exterior locks so only you hold working keys.',descZh:'剛入住？重設或更換外門鎖，確保只有你握有可用鑰匙。'},
      {id:'ducts',en:'Professional duct cleaning',zh:'專業風管清潔',sysEn:'HVAC',sysZh:'暖通空調',freq:'multiyr',months:[3],pri:'low',cost:{diy:null,proLow:300,proHigh:500},diff:'pro',descEn:'A deep professional cleaning removes dust and allergens built up in the ductwork over the years.',descZh:'深度專業清潔可清除多年累積在風管中的灰塵與過敏原。'},
      {id:'recaulk',en:'Re-caulk tubs, showers & sinks',zh:'重新填縫浴缸、淋浴間與水槽',sysEn:'Plumbing',sysZh:'水管',freq:'multiyr',months:[6],pri:'low',cost:{diy:15,proLow:null,proHigh:null},diff:'easy',descEn:'Strip old caulk and reseal tubs, showers, and sinks to stop water seeping behind the tiles.',descZh:'刮除舊填縫並重新封塗浴缸、淋浴間與水槽，防止水滲入磁磚後方。'},
      {id:'paint',en:'Repaint / reseal exterior wood & trim',zh:'重新油漆 / 封塗外部木作與飾條',sysEn:'Exterior',sysZh:'外部',freq:'multiyr',months:[7],pri:'low',cost:{diy:80,proLow:800,proHigh:2500},diff:'pro',descEn:'Repaint or reseal exterior wood and trim to protect it against moisture, UV, and rot.',descZh:'重新油漆或封塗外部木作與飾條，抵禦濕氣、紫外線與腐爛。'}
    ];

    const FREQ = {
      monthly:{en:'Every month',zh:'每月'}, quarterly:{en:'Every 3 months',zh:'每 3 個月'},
      semi:{en:'Twice a year',zh:'每年兩次'}, annual:{en:'Once a year',zh:'每年一次'},
      seasonal:{en:'Seasonal',zh:'季節性'}, multiyr:{en:'Every 3–5 years',zh:'每 3–5 年'}
    };
    const DIFF = {easy:{en:'Easy DIY',zh:'簡單 DIY'},moderate:{en:'Moderate DIY',zh:'進階 DIY'},pro:{en:'Hire a pro',zh:'建議找專業'}};
    const PRI = {high:{en:'High',zh:'高'},med:{en:'Medium',zh:'中'},low:{en:'Low',zh:'低'}};
    const PRI_RANK = {high:0,med:1,low:2};

    const freqLabel = f => FREQ[f][lang];
    const diffLabel = d => DIFF[d][lang];
    const priLabel = p => PRI[p][lang];
    const taskName = t => lang==='zh'?t.zh:t.en;
    const taskSys = t => lang==='zh'?t.sysZh:t.sysEn;
    const taskDesc = t => lang==='zh'?t.descZh:t.descEn;

    function rruleFor(f){
      switch(f){
        case 'monthly': return 'FREQ=MONTHLY';
        case 'quarterly': return 'FREQ=MONTHLY;INTERVAL=3';
        case 'semi': return 'FREQ=MONTHLY;INTERVAL=6';
        case 'annual': return 'FREQ=YEARLY';
        case 'seasonal': return 'FREQ=YEARLY';
        case 'multiyr': return 'FREQ=YEARLY;INTERVAL=4';
      }
      return 'FREQ=YEARLY';
    }

    function visibleTasks(){
      return TASKS.filter(t=>{
        if(t.req && !STATE.features[t.req]) return false;
        if(t.heating && !t.heating.includes(STATE.heating)) return false;
        if(t.coldOnly && STATE.climate!=='cold') return false;
        if(t.firstYearOnly && STATE.age!=='new') return false;
        return true;
      }).map(t=>{
        const c = Object.assign({}, t);
        const oldHome = (STATE.age==='old'||STATE.age==='veryold');
        if(oldHome && ['roof','gfci','whflush','furnace','chimney'].includes(c.id)){
          if(c.pri==='med') c.pri='high';
          else if(c.pri==='low') c.pri='med';
          c.bumped = true;
        }
        if(STATE.age==='new' && c.id==='rekey') c.pri='med';
        return c;
      });
    }
    function monthTasks(tasks, m){
      return tasks.filter(t=> t.freq==='monthly' || t.months.includes(m))
                  .sort((a,b)=> PRI_RANK[a.pri]-PRI_RANK[b.pri]);
    }

    const money = n => n===0 ? tt('free') : '$'+n;
    function costFull(c, diff){
      const hasPro = c.proLow!=null, hasDiy = c.diy!=null;
      const proStr = hasPro ? '$'+c.proLow+'–'+c.proHigh : null;
      const diyLbl = tt('diyWord'), proLbl = tt('proWord');
      if(diff==='pro' || !hasDiy) return proLbl+' '+(proStr||'—');
      let s = diyLbl+' '+money(c.diy);
      if(hasPro) s += ' · '+proLbl+' '+proStr;
      return s;
    }
    const occPerYear = f => ({monthly:12,quarterly:4,semi:2,annual:1,seasonal:1,multiyr:0.25})[f]||1;
    function annualEstimate(tasks){
      let lo=0, hi=0;
      tasks.forEach(t=>{
        const c=t.cost, n=occPerYear(t.freq);
        const hasPro=c.proLow!=null, hasDiy=c.diy!=null;
        if(t.diff==='pro' || !hasDiy){ if(hasPro){ lo+=c.proLow*n; hi+=c.proHigh*n; } return; }
        if(STATE.diy==='pro' && hasPro){ lo+=c.proLow*n; hi+=c.proHigh*n; return; }
        lo+=c.diy*n; hi+=c.diy*n;
      });
      return {lo:Math.round(lo),hi:Math.round(hi)};
    }

    // Calendar helpers
    function nextDateForMonth(m){ const now=new Date(); let y=now.getFullYear(); if(m-1<now.getMonth()) y++; return new Date(y,m-1,1); }
    function nextDateMonthly(){ const now=new Date(); let y=now.getFullYear(), m=now.getMonth()+1; if(m>11){m=0;y++;} return new Date(y,m,1); }
    function ymd(d){ return ''+d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0'); }
    function taskStartDate(t){ if(t.freq==='monthly') return nextDateMonthly(); const m=(t.months&&t.months.length)?t.months[0]:1; return nextDateForMonth(m); }
    const plusDay = d => new Date(d.getTime()+86400000);
    const icsEscape = s => String(s).replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\n/g,'\\n');

    function googleLink(t){
      const start=taskStartDate(t), end=plusDay(start);
      const text=encodeURIComponent(taskName(t)+' — Well Maintained');
      const dates=ymd(start)+'/'+ymd(end);
      const recur=encodeURIComponent('RRULE:'+rruleFor(t.freq));
      const plainCost = t.cost.proLow!=null ? ('Pro $'+t.cost.proLow+'–'+t.cost.proHigh) : (t.cost.diy!=null?('DIY $'+t.cost.diy):'');
      const det=encodeURIComponent(taskSys(t)+' · '+freqLabel(t.freq)+' · '+diffLabel(t.diff)+(plainCost?(' · '+plainCost):'')+'\n\n'+taskDesc(t)+'\n\n'+(lang==='zh'?'來自你的 Well Maintained 智慧維護時程':'From your Well Maintained smart maintenance schedule'));
      return 'https://calendar.google.com/calendar/render?action=TEMPLATE&text='+text+'&dates='+dates+'&recur='+recur+'&details='+det;
    }

    function downloadICS(){
      const tasks=visibleTasks();
      let lines=['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Well Maintained//Smart Schedule//EN','CALSCALE:GREGORIAN','METHOD:PUBLISH'];
      const stamp=ymd(new Date())+'T090000Z';
      tasks.forEach(t=>{
        const start=taskStartDate(t), end=plusDay(start);
        const plainCost = t.cost.proLow!=null ? ('Pro $'+t.cost.proLow+'-'+t.cost.proHigh) : (t.cost.diy!=null?('DIY $'+t.cost.diy):'');
        const desc=taskSys(t)+' | '+freqLabel(t.freq)+' | '+diffLabel(t.diff)+(plainCost?(' | '+plainCost):'')+' | '+taskDesc(t);
        lines.push('BEGIN:VEVENT');
        lines.push('UID:'+t.id+'-'+ymd(start)+'@wellmaintained');
        lines.push('DTSTAMP:'+stamp);
        lines.push('DTSTART;VALUE=DATE:'+ymd(start));
        lines.push('DTEND;VALUE=DATE:'+ymd(end));
        lines.push('RRULE:'+rruleFor(t.freq));
        lines.push('SUMMARY:'+icsEscape(taskName(t)+' — Well Maintained'));
        lines.push('DESCRIPTION:'+icsEscape(desc));
        lines.push('CATEGORIES:'+icsEscape(taskSys(t)));
        lines.push('BEGIN:VALARM');lines.push('ACTION:DISPLAY');lines.push('DESCRIPTION:'+icsEscape(taskName(t)));lines.push('TRIGGER:-P2D');lines.push('END:VALARM');
        lines.push('END:VEVENT');
      });
      lines.push('END:VCALENDAR');
      const blob=new Blob([lines.join('\r\n')],{type:'text/calendar;charset=utf-8'});
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a'); a.href=url; a.download='well-maintained-schedule.ics';
      document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
    }

    // ===== Build static UI =====
    function optionsHTML(kind, sel){
      return OPTS[kind].map(([v,lbl])=> '<option value="'+v+'"'+(v===sel?' selected':'')+'>'+lbl[lang]+'</option>').join('');
    }
    function buildStaticUI(){
      document.getElementById('ss-panel').innerHTML =
        '<h2>'+tt('panelTitle')+'</h2>'+
        '<div class="ss-hint">'+tt('panelHint')+'</div>'+
        '<div class="ss-controls">'+
          '<div class="ss-ctl"><label>'+tt('climate')+'</label><select id="ss-climate">'+optionsHTML('climate',STATE.climate)+'</select></div>'+
          '<div class="ss-ctl"><label>'+tt('age')+'</label><select id="ss-age">'+optionsHTML('age',STATE.age)+'</select></div>'+
          '<div class="ss-ctl"><label>'+tt('heating')+'</label><select id="ss-heating">'+optionsHTML('heating',STATE.heating)+'</select></div>'+
          '<div class="ss-ctl"><label>'+tt('diy')+'</label><select id="ss-diy">'+optionsHTML('diy',STATE.diy)+'</select></div>'+
        '</div>'+
        '<div class="ss-feat-label">'+tt('featuresLabel')+'</div>'+
        '<div class="ss-chips" id="ss-chips"></div>';

      document.getElementById('ss-calcta').innerHTML =
        '<div class="ss-cta-txt">'+
          '<h3>'+tt('ctaTitle')+'</h3><p>'+tt('ctaDesc')+'</p>'+
          '<button class="ss-howlink" id="ss-howlink">'+tt('howLink')+'</button>'+
          '<div class="ss-howbox" id="ss-howbox"><div><b>'+tt('howIntro')+'</b></div><ol><li>'+tt('how1')+'</li><li>'+tt('how2')+'</li><li>'+tt('how3')+'</li></ol></div>'+
        '</div>'+
        '<div class="ss-acts"><button class="btn-primary" id="ss-download">'+tt('download')+'</button></div>';

      ['climate','age','heating','diy'].forEach(k=>{
        document.getElementById('ss-'+k).addEventListener('change', e=>{ STATE[k]=e.target.value; renderAll(); });
      });
      document.getElementById('ss-chips').addEventListener('click', e=>{
        const chip=e.target.closest('.ss-chip'); if(!chip) return;
        STATE.features[chip.getAttribute('data-key')] = !STATE.features[chip.getAttribute('data-key')]; renderAll();
      });
      document.getElementById('ss-download').addEventListener('click', downloadICS);
      document.getElementById('ss-howlink').addEventListener('click', ()=>{ document.getElementById('ss-howbox').classList.toggle('show'); });

      // calendar interactions (delegated, container persists)
      const outEl = document.getElementById('ss-out');
      outEl.addEventListener('click', e=>{
        if(e.target.closest('#ss-prev')){ STATE.month = STATE.month===1?12:STATE.month-1; renderMonth(visibleTasks()); return; }
        if(e.target.closest('#ss-next')){ STATE.month = STATE.month===12?1:STATE.month+1; renderMonth(visibleTasks()); return; }
        if(e.target.closest('#ss-today')){ STATE.month = currentMonth(); renderMonth(visibleTasks()); return; }
        const row=e.target.closest('[data-id]'); if(row) openDetail(row.getAttribute('data-id'));
      });
      outEl.addEventListener('keydown', e=>{
        if((e.key==='Enter'||e.key===' ')){ const row=e.target.closest('[data-id]'); if(row){ e.preventDefault(); openDetail(row.getAttribute('data-id')); } }
      });

      // modal interactions
      document.getElementById('ss-modal-bd').addEventListener('click', closeDetail);
      document.getElementById('ss-modal-card').addEventListener('click', e=>{ if(e.target.closest('#ss-modal-close')) closeDetail(); });
      document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeDetail(); });
    }

    function renderChips(){
      document.getElementById('ss-chips').innerHTML = FEATURE_DEFS.map(f=>
        '<div class="ss-chip '+(STATE.features[f.key]?'on':'')+'" data-key="'+f.key+'"><span class="dot"></span>'+f[lang]+'</div>'
      ).join('');
    }
    function stat(n,l,cls){ return '<div class="ss-stat"><div class="n '+cls+'">'+n+'</div><div class="l">'+l+'</div></div>'; }
    function renderSummary(tasks){
      const high=tasks.filter(t=>t.pri==='high').length;
      const diy=tasks.filter(t=>t.diff!=='pro').length;
      const est=annualEstimate(tasks);
      const estStr = est.hi>0 ? ('$'+est.lo+'–$'+est.hi) : '—';
      document.getElementById('ss-summary').innerHTML =
        stat(tasks.length, tt('totalTasks'),'plain')+
        stat(high, tt('highPri'),'amber')+
        stat(diy, tt('canDiy'),'')+
        stat(estStr, tt('yearly'),'plain');
    }
    function rowHTML(t){
      return '<div class="ss-row p-'+t.pri+'" data-id="'+t.id+'" role="button" tabindex="0">'+
        '<span class="ss-dot '+t.pri+'"></span>'+
        '<span class="ss-rowtitle">'+taskName(t)+'</span>'+
        '<span class="ss-rowtags"><span class="ss-badge '+t.diff+'">'+diffLabel(t.diff)+'</span></span>'+
        '<span class="ss-chev">›</span>'+
      '</div>';
    }
    function renderMonth(tasks){
      const m=STATE.month;
      const list=monthTasks(tasks,m);
      let html='<div class="ss-calnav">'+
        '<div class="ss-calnav-main">'+
          '<button class="ss-navbtn" id="ss-prev" aria-label="'+tt('prev')+'">‹</button>'+
          '<div class="ss-navlabel"><span class="m">'+MONTHS[lang][m-1]+'</span><span class="season">'+SEASON[lang][m]+'</span></div>'+
          '<button class="ss-navbtn" id="ss-next" aria-label="'+tt('next')+'">›</button>'+
        '</div>'+
        '<div class="ss-calnav-side"><span class="count">'+list.length+' '+tt('tasks')+(list.length?(' · '+tt('tapHint')):'')+'</span><button class="ss-today" id="ss-today">'+tt('thisMonth')+'</button></div>'+
      '</div>';
      html += list.length ? ('<div class="ss-rows">'+list.map(rowHTML).join('')+'</div>') : ('<div class="ss-empty">'+tt('emptyMonth')+'</div>');
      document.getElementById('ss-out').innerHTML = html;
    }

    function openDetail(id){
      const t=visibleTasks().find(x=>x.id===id); if(!t) return;
      const bumped = t.bumped ? ' <span class="ss-note">('+tt('bumped')+')</span>' : '';
      document.getElementById('ss-modal-card').innerHTML =
        '<button class="ss-modal-close" id="ss-modal-close" aria-label="close">×</button>'+
        '<span class="ss-pri '+t.pri+'">'+priLabel(t.pri)+bumped+'</span>'+
        '<h3 class="ss-modal-title">'+taskName(t)+'</h3>'+
        '<div class="ss-modal-sys">'+taskSys(t)+' · '+freqLabel(t.freq)+'</div>'+
        '<p class="ss-modal-desc">'+taskDesc(t)+'</p>'+
        '<div class="ss-modal-meta">'+
          '<div class="ss-modal-line"><span class="k">'+tt('difficulty')+'</span><span class="ss-badge '+t.diff+'">🔧 '+diffLabel(t.diff)+'</span></div>'+
          '<div class="ss-modal-line"><span class="k">'+tt('estCost')+'</span><span class="v">💰 '+costFull(t.cost,t.diff)+'</span></div>'+
        '</div>'+
        '<a class="ss-gcal ss-modal-gcal" target="_blank" rel="noopener" href="'+googleLink(t)+'">📅 '+tt('gcal')+'</a>';
      const modal=document.getElementById('ss-modal');
      modal.removeAttribute('hidden');
      document.body.style.overflow='hidden';
    }
    function closeDetail(){
      const modal=document.getElementById('ss-modal');
      if(modal.hasAttribute('hidden')) return;
      modal.setAttribute('hidden','');
      document.body.style.overflow='';
    }

    function renderAll(){
      const tasks=visibleTasks();
      renderChips(); renderSummary(tasks); renderMonth(tasks);
    }

    buildStaticUI();
    renderAll();
  }
</script>
