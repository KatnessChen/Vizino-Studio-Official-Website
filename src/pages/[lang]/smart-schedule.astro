        panelHint:'下方時程會即時更新。這與我們為你親手核對的真實計畫採用相同邏輯。',
        climate:'氣候', age:'屋齡', heating:'暖氣系統', diy:'你傾向…',
        featuresLabel:'你家有…（點擊切換）',
        ctaTitle:'讓你的一整年自動運轉',
        ctaDesc:'把所有任務下載成一個行事曆檔（Google、Apple 或 Outlook）— 每項都會自動重複並提醒你。或點開任一任務，直接加入 Google 行事曆。',
        howLink:'如何匯入 Google 行事曆？',
        howIntro:'在電腦上：',
        how1:'開啟 Google 行事曆 → ⚙ 設定 → 匯入與匯出。',
        how2:'選擇剛下載的檔案（well-maintained-schedule.ics）。',
        how3:'選擇要加入哪個行事曆，按匯入。完成。',
        download:'📅 全部加入行事曆',
        yearly:'粗估年度費用 *', highPri:'高優先（先做這些）', canDiy:'你可以自己動手', totalTasks:'維護任務 / 年',
        tasks:'項', prev:'上個月', next:'下個月', thisMonth:'本月',
        emptyMonth:'這個月沒有排定的維護——好好休息。',
        empty:'沒有符合的任務 — 試著開啟上方的房屋功能。',
        gcal:'加入 Google 行事曆', bumped:'因屋齡提高',
        difficulty:'難度', estCost:'預估費用', tapHint:'點任一任務看詳情',
        diyWord:'自己做', proWord:'專業', free:'免費'
      }
    };
    const tt = (k) => T[lang][k];

    const OPTS = {
      climate: [['cold',{en:'Cold winters (e.g. Ottawa)',zh:'寒冷冬季（如渥太華）'}],['temperate',{en:'Mild / temperate',zh:'溫和氣候'}]],
      age: [['new',{en:'0–5 years (new)',zh:'0–5 年（新屋）'}],['mid',{en:'6–15 years',zh:'6–15 年'}],['older',{en:'16–30 years',zh:'16–30 年'}],['old',{en:'31–50 years',zh:'31–50 年'}],['veryold',{en:'50+ years',zh:'50 年以上'}]],
      heating: [['gas',{en:'Forced-air gas furnace',zh:'天然氣熱風爐'}],['electric',{en:'Electric',zh:'電力'}],['heatpump',{en:'Heat pump',zh:'熱泵'}],['boiler',{en:'Boiler / radiant',zh:'鍋爐 / 地暖'}]],
      diy: [['diy',{en:'Do it myself',zh:'自己動手做'}],['mix',{en:'DIY simple, hire the rest',zh:'簡單自己做，其餘外包'}],['pro',{en:'Hire professionals',zh:'幾乎都找專業'}]]
    };

    const MONTHS = {
      en:['January','February','March','April','May','June','July','August','September','October','November','December'],
      zh:['一月','二月','三月','四月','五月','六月','七月','八月','九月','十月','十一月','十二月']
    };
    const SEASON = {
      en:{1:'Winter',2:'Winter',3:'Spring',4:'Spring',5:'Spring',6:'Summer',7:'Summer',8:'Summer',9:'Fall',10:'Fall',11:'Fall',12:'Winter'},
      zh:{1:'冬',2:'冬',3:'春',4:'春',5:'春',6:'夏',7:'夏',8:'夏',9:'秋',10:'秋',11:'秋',12:'冬'}
    };
    const FEATURE_DEFS = [
      {key:'gutters',en:'Gutters',zh:'排水溝'},{key:'sump',en:'Sump pump',zh:'排水泵'},
      {key:'fireplace',en:'Fireplace / chimney',zh:'壁爐 / 煙囪'},{key:'garage',en:'Garage door opener',zh:'電動車庫門'},
      {key:'deck',en:'Deck / patio',zh:'木甲板 / 露台'},{key:'irrigation',en:'Irrigation',zh:'灑水系統'},
      {key:'pool',en:'Pool',zh:'泳池'},{key:'trees',en:'Mature trees',zh:'屋旁大樹'}
    ];

    const TASKS = [
      {id:'smoke',en:'Test all smoke & CO alarms',zh:'測試所有煙霧與一氧化碳警報器',sysEn:'Safety',sysZh:'安全',freq:'monthly',months:[],pri:'high',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:'Press the test button on each alarm; replace batteries if the sound is weak. Working alarms are your first line of defense.',descZh:'按下每個警報器的測試鈕；聲音微弱就換電池。能運作的警報器是你的第一道防線。'},
      {id:'filtercheck',en:'Check furnace / HVAC filter',zh:'檢查暖氣 / 空調濾網',sysEn:'HVAC',sysZh:'暖通空調',freq:'monthly',months:[],pri:'med',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:"Hold the filter up to the light — if you can't see through it, it's time to change. A clogged filter strains the whole system.",descZh:'把濾網對著光看——看不透就該換了。濾網阻塞會讓整個系統更耗損。'},
      {id:'rangehood',en:'Clean range hood filter',zh:'清潔抽油煙機濾網',sysEn:'Kitchen',sysZh:'廚房',freq:'monthly',months:[],pri:'low',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:'Soak the metal mesh filter in hot, soapy water to clear grease buildup and reduce kitchen fire risk.',descZh:'把金屬濾網泡在熱肥皂水中，去除油垢、降低廚房火災風險。'},
      {id:'leakcheck',en:'Check under sinks & around toilets for leaks',zh:'檢查水槽下方與馬桶周圍是否漏水',sysEn:'Plumbing',sysZh:'水管',freq:'monthly',months:[],pri:'med',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:'Look and feel for drips, stains, or warped wood. Catching a slow leak early prevents rot and mold.',descZh:'檢查有無滴水、水漬或木材變形。及早發現慢漏可避免腐爛與發霉。'},
      {id:'filterreplace',en:'Replace furnace / HVAC filter',zh:'更換暖氣 / 空調濾網',sysEn:'HVAC',sysZh:'暖通空調',freq:'quarterly',months:[1,4,7,10],pri:'med',cost:{diy:25,proLow:null,proHigh:null},diff:'easy',descEn:'Swap in a fresh filter. Clean airflow keeps heating and cooling efficient and the air healthier.',descZh:'換上全新濾網。順暢的氣流能維持冷暖效率，空氣也更健康。'},
      {id:'gfci',en:'Test GFCI & AFCI outlets / breakers',zh:'測試 GFCI 與 AFCI 插座 / 斷路器',sysEn:'Electrical · Safety',sysZh:'電力 · 安全',freq:'quarterly',months:[1,4,7,10],pri:'high',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:'Press TEST then RESET on each device. These protect you from electric shock and electrical fires.',descZh:'在每個裝置上按 TEST 再 RESET。它們能防止觸電與電氣火災。'},
      {id:'drains',en:'Run water in unused drains to fill traps',zh:'在少用的排水孔放水，補滿存水彎',sysEn:'Plumbing',sysZh:'水管',freq:'quarterly',months:[1,4,7,10],pri:'low',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',descEn:'Pour water into floor drains and unused sinks so the trap stays full and sewer gas cannot enter.',descZh:'在地排和少用的水槽倒水，讓存水彎保持滿水、阻隔下水道氣味。'},
      {id:'ac',en:'A/C pre-season check',zh:'冷氣季前檢查',sysEn:'HVAC',sysZh:'暖通空調',freq:'annual',months:[4],pri:'med',cost:{diy:null,proLow:100,proHigh:180},diff:'pro',descEn:'Have a tech check refrigerant, coils, and airflow before summer so the A/C is ready when you need it.',descZh:'夏天前請技師檢查冷媒、盤管與氣流，讓冷氣在你需要時就緒。'},
      {id:'sumptest',en:'Test sump pump & backup',zh:'測試排水泵與備援系統',sysEn:'Water · Safety',sysZh:'防水 · 安全',freq:'annual',months:[3],pri:'high',cost:{diy:0,proLow:null,proHigh:null},diff:'easy',req:'sump',descEn:'Pour a bucket of water into the pit — the pump should switch on and drain it. Test the battery backup too.',descZh:'倒一桶水進集水坑——幫浦應啟動並排乾。也測試備援電池。'},
