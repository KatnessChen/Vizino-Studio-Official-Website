---
import Layout from '../../layouts/Layout.astro';
import { ui } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh-tw' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);
---

<Layout title={t('meta.title')} description={t('meta.description')} lang={lang}>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-headline">{t('hero.headline')}</h1>
      <p class="hero-desc">{t('hero.description')}</p>
      <a href={`/${lang}/waitlist/`} class="btn-primary">{t('hero.cta')} &rarr;</a>
    </div>
    <div class="hero-visual">
      <div class="hero-glow"></div>
      <div class="hero-card">
        <div class="hero-card-title">{t('hero.card.title')}</div>
        <div class="hero-card-row">
          <span class="hero-card-month">{t('hero.card.m1')}</span>
          <span class="hero-card-task">{t('hero.card.t1')}</span>
          <span class="hero-card-dot"></span>
        </div>
        <div class="hero-card-row">
          <span class="hero-card-month">{t('hero.card.m2')}</span>
          <span class="hero-card-task">{t('hero.card.t2')}</span>
          <span class="hero-card-dot"></span>
        </div>
        <div class="hero-card-row">
          <span class="hero-card-month">{t('hero.card.m3')}</span>
          <span class="hero-card-task">{t('hero.card.t3')}</span>
          <span class="hero-card-dot"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROBLEM ═══ -->
  <section class="section-full section-dark" id="problem">
    <div class="section">
      <div class="problem-text">
        <h2 class="section-headline center">
          {t('problem.headline')}<br/>
          <em class="accent-text">{t('problem.headline.em')}</em>
        </h2>
        <p class="section-desc center">{t('problem.description')}</p>
      </div>
      <div class="pain-row">
        <div class="pain-card">
          <div class="pain-icon">&#129335;</div>
          <h3>{t('problem.pain1.title')}</h3>
          <p>{t('problem.pain1.desc')}</p>
        </div>
        <div class="pain-card">
          <div class="pain-icon">&#128184;</div>
          <h3>{t('problem.pain2.title')}</h3>
          <p>{t('problem.pain2.desc')}</p>
        </div>
        <div class="pain-card">
          <div class="pain-icon">&#128553;</div>
          <h3>{t('problem.pain3.title')}</h3>
          <p>{t('problem.pain3.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="section" id="how">
    <h2 class="section-headline center">{t('how.headline')}</h2>
    <div class="steps-row">
      <div class="step-card">
        <div class="step-number">1</div>
        <h3 class="step-title">{t('how.step1.title')}</h3>
        <p class="step-desc">{t('how.step1.desc')}</p>
      </div>
      <div class="step-connector"><svg width="40" height="2"><line x1="0" y1="1" x2="40" y2="1" stroke="var(--accent)" stroke-width="2" stroke-dasharray="4 4"/></svg></div>
      <div class="step-card">
        <div class="step-number">2</div>
        <h3 class="step-title">{t('how.step2.title')}</h3>
        <p class="step-desc">{t('how.step2.desc')}</p>
      </div>
      <div class="step-connector"><svg width="40" height="2"><line x1="0" y1="1" x2="40" y2="1" stroke="var(--accent)" stroke-width="2" stroke-dasharray="4 4"/></svg></div>
      <div class="step-card">
        <div class="step-number">3</div>
        <h3 class="step-title">{t('how.step3.title')}</h3>
        <p class="step-desc">{t('how.step3.desc')}</p>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT'S IN YOUR PLAN ═══ -->
  <section class="section-full section-dark" id="plan">
    <div class="section">
      <h2 class="section-headline center">{t('plan.headline')}</h2>
      <div class="plan-grid">
        <div class="plan-item"><div class="plan-icon">&#127919;</div><h4>{t('plan.score.title')}</h4><p>{t('plan.score.desc')}</p></div>
        <div class="plan-item"><div class="plan-icon">&#128197;</div><h4>{t('plan.schedule.title')}</h4><p>{t('plan.schedule.desc')}</p></div>
        <div class="plan-item"><div class="plan-icon">&#128176;</div><h4>{t('plan.cost.title')}</h4><p>{t('plan.cost.desc')}</p></div>
        <div class="plan-item"><div class="plan-icon">&#128295;</div><h4>{t('plan.diy.title')}</h4><p>{t('plan.diy.desc')}</p></div>
        <div class="plan-item"><div class="plan-icon">&#128276;</div><h4>{t('plan.reminders.title')}</h4><p>{t('plan.reminders.desc')}</p></div>
        <div class="plan-item"><div class="plan-icon">&#9989;</div><h4>{t('plan.book.title')}</h4><p>{t('plan.book.desc')}</p></div>
      </div>
    </div>
  </section>

  <!-- ═══ FOR INSPECTORS ═══ -->
  <section class="section-full section-dark" id="inspectors">
    <div class="section">
      <h2 class="section-headline">{t('inspectors.headline')}</h2>
      <p class="section-desc">{t('inspectors.description')}</p>
      <p class="inspector-pitch">{t('inspectors.pitch')}</p>
      <ul class="inspector-benefits">
        <li>{t('inspectors.b1')}</li>
        <li>{t('inspectors.b2')}</li>
        <li>{t('inspectors.b3')}</li>
        <li>{t('inspectors.b4')}</li>
      </ul>
      <a href="mailto:inspectors@wellmaintained.ca" class="btn-outline">{t('inspectors.cta')} &rarr;</a>
    </div>
  </section>

  <!-- ═══ FOUNDER ═══ -->
  <section class="section" id="founder">
    <div class="founder-block">
      <h2 class="section-headline">{t('founder.headline')}</h2>
      <blockquote class="founder-quote">&ldquo;{t('founder.quote')}&rdquo;</blockquote>
      <p class="founder-name">{t('founder.name')}</p>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="section-full cta-section">
    <div class="section cta-inner">
      <h2 class="section-headline center">{t('cta.headline')}</h2>
      <p class="section-desc center">{t('cta.description')}</p>
      <a href={`/${lang}/waitlist/`} class="btn-primary btn-lg">{t('cta.button')} &rarr;</a>
      <p class="cta-note">{t('cta.note')}</p>
    </div>
  </section>

</Layout>

<style>
  /* ═══ HERO ═══ */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 120px 24px 80px;
    gap: 60px;
  }
  .hero-content { flex: 1; max-width: 580px; }
  .hero-headline {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .hero-desc {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 500px;
  }
  .hero-visual {
    flex: 0 0 auto;
    position: relative;
    width: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-glow {
    position: absolute;
    width: 280px; height: 280px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    border-radius: 50%;
    animation: pulse 4s ease-in-out infinite;
  }
  .hero-card {
    position: relative;
    width: 100%;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 22px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px var(--accent-glow);
  }
  .hero-card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  .hero-card-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-top: 1px solid var(--border);
  }
  .hero-card-month {
    flex: 0 0 auto;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    width: 40px;
  }
  .hero-card-task {
    flex: 1;
    font-size: 14px;
    color: var(--text-secondary);
    text-align: left;
  }
  .hero-card-dot {
    flex: 0 0 auto;
    width: 16px; height: 16px;
    border: 2px solid var(--accent);
    border-radius: 50%;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.12); opacity: 1; }
  }
  @media (max-width: 768px) {
    .hero { flex-direction: column; text-align: center; padding-top: 100px; min-height: auto; }
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-visual { width: 100%; max-width: 360px; }
  }

  /* ═══ BUTTONS ═══ */
  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: var(--bg-primary);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 16px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    text-align: center;
  }
  .btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); }
  .btn-lg { font-size: 18px; padding: 18px 40px; }
  .btn-outline {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 16px;
    transition: border-color 0.2s, color 0.2s;
    text-align: center;
  }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  .btn-amber {
    display: inline-block;
    background: var(--amber);
    color: var(--bg-primary);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 16px;
    transition: background 0.2s, transform 0.2s;
    text-align: center;
  }
  .btn-amber:hover { background: #ffc520; transform: translateY(-1px); }

  /* ═══ SECTIONS ═══ */
  .section-headline {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .section-headline.center { text-align: center; }
  .accent-text { color: var(--accent); font-style: normal; }
  .section-desc {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 620px;
  }
  .section-desc.center { text-align: center; margin: 0 auto 40px; }

  /* ═══ PROBLEM ═══ */
  .problem-text { margin-bottom: 48px; }
  .pain-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .pain-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 24px;
    text-align: center;
  }
  .pain-icon { font-size: 32px; margin-bottom: 12px; }
  .pain-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
  .pain-card p { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }
  @media (max-width: 640px) { .pain-row { grid-template-columns: 1fr; } }

  /* ═══ STEPS ═══ */
  .steps-row {
    display: flex;
    align-items: flex-start;
    margin-top: 48px;
    justify-content: center;
  }
  .step-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    flex: 1;
    max-width: 320px;
  }
  .step-number {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: var(--accent); color: var(--bg-primary);
    font-weight: 800; font-size: 16px; border-radius: 50%;
    margin-bottom: 16px;
  }
  .step-title { font-size: 18px; font-weight: 600; margin-bottom: 10px; }
  .step-desc { font-size: 15px; color: var(--text-secondary); line-height: 1.7; }
  .step-connector { display: flex; align-items: center; padding-top: 40px; }
  @media (max-width: 768px) {
    .steps-row { flex-direction: column; align-items: center; gap: 16px; }
    .step-connector { display: none; }
    .step-card { max-width: 100%; }
  }

  /* ═══ PLAN GRID ═══ */
  .plan-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .plan-item {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
  }
  .plan-icon { font-size: 28px; margin-bottom: 10px; }
  .plan-item h4 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
  .plan-item p { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
  @media (max-width: 768px) { .plan-grid { grid-template-columns: 1fr; } }

  /* ═══ PRICING ═══ */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
    align-items: start;
  }
  .price-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .price-card.featured {
    border-color: var(--accent);
    box-shadow: 0 0 40px var(--accent-glow);
  }
  .price-card.onsite {
    border-color: var(--amber);
    box-shadow: 0 0 40px rgba(255, 184, 0, 0.1);
  }
  .price-badge {
    position: absolute; top: -12px; right: 24px;
    background: var(--amber); color: var(--bg-primary);
    font-size: 11px; font-weight: 700; padding: 4px 12px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: 1px;
  }
  .price-name { font-size: 20px; font-weight: 600; margin-bottom: 8px; }
  .price-amount { font-size: 44px; font-weight: 800; margin-bottom: 16px; }
  .price-period { font-size: 18px; font-weight: 500; color: var(--text-secondary); }
  .price-includes { font-size: 13px; color: var(--text-tertiary); margin-bottom: 8px; font-weight: 500; }
  .price-features {
    list-style: none; padding: 0; margin-bottom: 28px; flex: 1;
  }
  .price-features li {
    font-size: 15px; color: var(--text-secondary);
    padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-left: 20px; position: relative;
  }
  .price-features li::before {
    content: '\2713'; position: absolute; left: 0;
    color: var(--accent); font-weight: 700;
  }
  .price-card.onsite .price-features li::before { color: var(--amber); }
  .price-card a { width: 100%; text-align: center; }
  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
  }

  /* ═══ INSPECTORS ═══ */
  .inspector-pitch {
    font-size: 16px; color: var(--text-secondary);
    line-height: 1.7; margin: 16px 0 24px; max-width: 620px;
  }
  .inspector-benefits {
    list-style: none; padding: 0; margin-bottom: 32px;
  }
  .inspector-benefits li {
    font-size: 16px; color: var(--text-secondary);
    padding: 8px 0 8px 24px; position: relative;
  }
  .inspector-benefits li::before {
    content: '\2713'; position: absolute; left: 0;
    color: var(--accent); font-weight: 700;
  }

  /* ═══ FOUNDER ═══ */
  .founder-block { max-width: 680px; margin: 0 auto; text-align: center; }
  .founder-quote {
    font-size: 19px; line-height: 1.8; color: var(--text-secondary);
    font-style: italic; margin: 28px 0 20px;
    border-left: 3px solid var(--accent); padding-left: 24px; text-align: left;
  }
  .founder-name { font-size: 15px; font-weight: 600; color: var(--text-tertiary); }

  /* ═══ FINAL CTA ═══ */
  .cta-section {
    background: linear-gradient(180deg, var(--bg-primary) 0%, rgba(0, 212, 170, 0.05) 50%, var(--bg-primary) 100%);
  }
  .cta-inner { text-align: center; }
  .cta-note {
    margin-top: 16px;
    font-size: 14px;
    color: var(--text-tertiary);
  }

  /* ═══ Scroll-in ═══ */
  .pain-card, .step-card, .plan-item, .price-card, .founder-block {
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .pain-card.visible, .step-card.visible, .plan-item.visible,
  .price-card.visible, .founder-block.visible {
    opacity: 1; transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.pain-card, .step-card, .plan-item, .price-card, .founder-block').forEach(el => observer.observe(el));
</script>
